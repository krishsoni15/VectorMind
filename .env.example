# Supabase Configuration
# For hosted instance keys head to https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# AI Provider Keys
# You must provide at least one embedding provider and one chat provider.

# Chat & Embedding
# Get your free key at https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# Chat & Embedding
# Get your free key at https://ai.google.dev/
GEMINI_API_KEY=

# Chat Only (Ultra-fast Llama 3.3 70B)
# Get your free key at https://console.groq.com/keys
GROQ_API_KEY=

# Chat + Embedding (ChatGPT / OpenAI)
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=